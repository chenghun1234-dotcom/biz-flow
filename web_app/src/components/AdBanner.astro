---
// AdBanner.astro — 광고 슬롯 (AdFit/A-Sense 실제 코드로 교체)
export interface Props {
  slot_id?: string;
  label?:   string;
}
const { slot_id = 'top', label = '광고' } = Astro.props;
---


<div class="ad-wrap" data-slot={slot_id}>
  {/* 카카오 애드핏 300x250 광고 (slot_id === 'kakao-300x250' 일 때만 노출) */}
  {slot_id === 'kakao-300x250' && (
    <>
      <ins class="kakao_ad_area" style="display:none;"
        data-ad-unit="DAN-Og4rHGPv1Zg5DekB"
        data-ad-width="300"
        data-ad-height="250"></ins>
      <script type="text/javascript" src="//t1.daumcdn.net/kas/static/ba.min.js" async></script>
    </>
  )}

  {/* 개발 중 플레이스홀더 (카카오 광고가 아닐 때만 노출) */}
  {slot_id !== 'kakao-300x250' && (
    <div class="ad-placeholder">
      <span>📢 {label}</span>
    </div>
  )}
</div>

<style>
.ad-wrap {
  width: 100%;
  margin: 12px 0;
  text-align: center;
}

.ad-placeholder {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  width: 100%;
  max-width: 728px;
  height: 72px;
  background: var(--color-surface-grey);
  border: 1px dashed #D1D5DB;
  border-radius: 8px;
  color: var(--color-text-muted);
  font-size: 13px;
  margin: 0 auto;
}
</style>
