---
import BaseLayout from '../layouts/BaseLayout.astro';
import PolicyCard from '../components/PolicyCard.astro';
import LeadModal from '../components/LeadModal.astro';
import AdBanner from '../components/AdBanner.astro';
import '../styles/global.css';

// 빌드 타임에 JSON 로드
import policiesData from '../../public/data/policies.json';

const policies = policiesData as Array<{
  id:         string;
  title:      string;
  deadline:   string;
  is_loan:    boolean;
  summary:    string;
  cert_bonus: string;
  url:        string;
}>;

const totalGrant  = policies.filter(p => !p.is_loan).length;
const totalLoan   = policies.filter(p =>  p.is_loan).length;
const totalAmount = policies.length;
---

<BaseLayout
  title="Biz-Flow | 맞춤형 지원제도 플랫폼 — 소상공인·중소기업 보조금·융자 한눈에"
  description={`현재 ${totalAmount}개 지원사업 운영 중. 보조금 ${totalGrant}개, 융자 ${totalLoan}개. 업종·매출별 맞춤 필터링.`}
>
  <!-- ── 히어로 배너 ─────────────────────── -->
  <section class="hero">
    <div class="container hero__inner">
      <div class="hero__stats">
        <span class="hero__stat">🎁 보조금 <strong>{totalGrant}</strong></span>
        <span class="hero__divider">|</span>
        <span class="hero__stat">💰 융자 <strong>{totalLoan}</strong></span>
        <span class="hero__divider">|</span>
        <span class="hero__stat">총 <strong>{totalAmount}</strong>개 운영 중</span>
      </div>
      <h1 class="hero__title">
        내 사업에 맞는<br/>
        <span class="hero__accent">정부지원사업</span>을 찾아드립니다
      </h1>
      <p class="hero__desc">
        보조금·융자·바우처를 한눈에. 업종과 매출 기준으로 맞춤 필터링하세요.<br/>
        전문가 무료 상담으로 최적 지원사업을 바로 적용할 수 있습니다.
      </p>
      <div class="hero__ctas">
        <button class="btn btn--surface consult-btn" data-title="">
          🎯 무료 맞춤 상담 신청
        </button>
        <a href="#programs" class="btn btn--ghost-white">지원사업 둘러보기 ↓</a>
      </div>
    </div>
    <!-- 배경 데코 -->
    <div class="hero__deco" aria-hidden="true"></div>
  </section>

  <!-- ── 상단 광고 ──────────────────────── -->
  <div class="container" style="margin-top:24px;">
    <AdBanner slot_id="top-banner" label="광고 영역 (728×90)" />
  </div>

  <!-- ── 필터 + 카드 그리드 ──────────────── -->
  <section id="programs" class="programs-section">
    <div class="container">

      <!-- 필터 탭 -->
      <div class="filter-bar" role="tablist" aria-label="지원유형 필터">
        <button class="filter-tab is-active" data-filter="all"    role="tab" aria-selected="true">전체</button>
        <button class="filter-tab"           data-filter="grant"  role="tab" aria-selected="false">🎁 보조금</button>
        <button class="filter-tab"           data-filter="loan"   role="tab" aria-selected="false">💰 융자</button>
      </div>

      <!-- 결과 카운트 -->
      <p class="result-count" id="result-count">{totalAmount}개 지원사업</p>

      <!-- 카드 그리드 -->
      <div class="card-grid" id="card-grid">
        {policies.map(p => (
          <PolicyCard
            id={p.id}
            title={p.title}
            deadline={p.deadline}
            is_loan={p.is_loan}
            summary={p.summary}
            cert_bonus={p.cert_bonus}
            url={p.url}
          />
        ))}
      </div>

      <!-- 빈 상태 -->
      <div id="empty-state" class="empty-state" style="display:none">
        <p>😅 해당 조건의 지원사업이 없습니다.</p>
      </div>
    </div>
  </section>

  <!-- ── 하단 광고 ──────────────────────── -->
  <div class="container" style="margin-top:32px;">
    <AdBanner slot_id="bottom-banner" label="광고 영역 (728×90)" />
  </div>

  <!-- ── 상담 CTA 섹션 ─────────────────── -->
  <section class="cta-section">
    <div class="container cta-inner">
      <h2 class="cta-title">🔍 어떤 지원사업이 맞는지 모르겠나요?</h2>
      <p class="cta-desc">업종·매출·업력을 알려주시면 담당 전문가가 직접 분석해드립니다.</p>
      <button class="btn btn--surface consult-btn" data-title="">무료 맞춤 상담 신청 →</button>
    </div>
  </section>

  <!-- 상담 모달 -->
  <LeadModal />
</BaseLayout>

<script>
// 필터링 로직
const tabs   = document.querySelectorAll<HTMLButtonElement>('.filter-tab');
const cards  = document.querySelectorAll<HTMLElement>('.policy-card');
const count  = document.getElementById('result-count')!;
const empty  = document.getElementById('empty-state')!;

tabs.forEach(tab => {
  tab.addEventListener('click', () => {
    tabs.forEach(t => { t.classList.remove('is-active'); t.setAttribute('aria-selected','false'); });
    tab.classList.add('is-active');
    tab.setAttribute('aria-selected','true');

    const f = tab.dataset.filter!;
    let visible = 0;

    cards.forEach(card => {
      const isLoan = card.dataset.loan === 'true';
      const show = f === 'all'
        || (f === 'grant' && !isLoan)
        || (f === 'loan'  &&  isLoan);
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });

    count.textContent = `${visible}개 지원사업`;
    empty.style.display = visible === 0 ? 'block' : 'none';
  });
});
</script>

<style>
/* ── 히어로 ─────────────────────────────── */
.hero {
  position: relative;
  background: var(--gradient-hero);
  color: #fff;
  padding: 64px 0 72px;
  overflow: hidden;
}

.hero__inner { position: relative; z-index: 1; }

.hero__stats {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 16px;
  flex-wrap: wrap;
}

.hero__stat { font-size: 14px; opacity: 0.9; }
.hero__stat strong { font-weight: 800; }
.hero__divider { opacity: 0.4; }

.hero__title {
  font-size: clamp(28px, 5vw, 44px);
  font-weight: 800;
  line-height: 1.3;
  margin-bottom: 16px;
  letter-spacing: -0.5px;
}

.hero__accent { color: #7EFFC5; }

.hero__desc {
  font-size: 15px;
  opacity: 0.88;
  line-height: 1.7;
  margin-bottom: 28px;
  max-width: 580px;
}

.hero__ctas {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
}

.btn--surface {
  background: #fff;
  color: var(--color-primary);
  font-weight: 700;
  padding: 14px 28px;
  border-radius: var(--radius-button);
}
.btn--surface:hover { background: #f0f4ff; }

.btn--ghost-white {
  background: transparent;
  color: #fff;
  border: 1.5px solid rgba(255,255,255,0.55);
  padding: 14px 28px;
  border-radius: var(--radius-button);
  font-weight: 600;
  font-size: 14px;
}
.btn--ghost-white:hover { background: rgba(255,255,255,0.12); }

.hero__deco {
  position: absolute;
  top: -80px; right: -80px;
  width: 400px; height: 400px;
  border-radius: 50%;
  background: rgba(255,255,255,0.05);
  pointer-events: none;
}

/* ── 필터 바 ────────────────────────────── */
.programs-section { padding: 36px 0 48px; }

.filter-bar {
  display: flex;
  gap: 8px;
  margin-bottom: 20px;
  flex-wrap: wrap;
}

.filter-tab {
  padding: 8px 20px;
  border-radius: var(--radius-tag);
  font-size: 14px;
  font-weight: 600;
  background: var(--color-surface);
  border: 1.5px solid var(--color-divider);
  color: var(--color-text-secondary);
  transition: all 0.15s;
}

.filter-tab:hover {
  border-color: var(--color-primary);
  color: var(--color-primary);
}

.filter-tab.is-active {
  background: var(--color-primary);
  border-color: var(--color-primary);
  color: #fff;
}

.result-count {
  font-size: 13px;
  color: var(--color-text-muted);
  margin-bottom: 20px;
}

/* ── 카드 그리드 ────────────────────────── */
.card-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 20px;
}

.empty-state {
  text-align: center;
  padding: 60px 0;
  color: var(--color-text-muted);
  font-size: 16px;
}

/* ── CTA 섹션 ───────────────────────────── */
.cta-section {
  background: var(--color-primary);
  color: #fff;
  padding: 52px 0;
  margin-top: 20px;
}

.cta-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 12px;
}

.cta-title {
  font-size: clamp(20px, 3.5vw, 28px);
  font-weight: 800;
}

.cta-desc {
  font-size: 15px;
  opacity: 0.88;
  margin-bottom: 8px;
}
</style>
