    <AdBanner slot_id="bottom-banner" label="광고 영역 (728×90)" />
  </div>
</BaseLayout>

<script>
// 현재 필터 상태
let activeType   = 'all';
let activeTarget = 'all';

const typeTabs   = document.querySelectorAll<HTMLButtonElement>('.filter-tab');
const catBtns    = document.querySelectorAll<HTMLButtonElement>('.cat-btn');
const cards      = document.querySelectorAll<HTMLElement>('.policy-card');
const countEl    = document.getElementById('result-count')!;
const emptyEl    = document.getElementById('empty-state')!;

function applyFilter() {
  let visible = 0;
  cards.forEach(card => {
    const isLoan   = card.dataset.loan   === 'true';
    const target   = card.dataset.target ?? '';

    const typeOk   = activeType   === 'all'
      || (activeType === 'grant' && !isLoan)
      || (activeType === 'loan'  &&  isLoan);

    const targetOk = activeTarget === 'all' || target === activeTarget;

    const show = typeOk && targetOk;
    card.style.display = show ? '' : 'none';
    if (show) visible++;
  });
  countEl.textContent = `${visible}개 지원사업`;
  emptyEl.style.display = visible === 0 ? 'block' : 'none';
}

// 지원유형 탭
typeTabs.forEach(tab => {
  tab.addEventListener('click', () => {
    typeTabs.forEach(t => t.classList.remove('is-active'));
    tab.classList.add('is-active');
    activeType = tab.dataset.type!;
    applyFilter();
  });
});

// 업종 카테고리 버튼
catBtns.forEach(btn => {
  btn.addEventListener('click', () => {
    catBtns.forEach(b => b.classList.remove('is-active'));
    btn.classList.add('is-active');
    activeTarget = btn.dataset.target!;
    applyFilter();
  });
});
</script>

